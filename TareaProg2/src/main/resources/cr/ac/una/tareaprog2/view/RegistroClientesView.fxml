<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="600.0" styleClass="registrar-cliente-anchor" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.tareaprog2.controller.ClienteController">
    <children>
        
        <Label layoutX="240.0" layoutY="14.0" styleClass="registrar-cliente-titulo" stylesheets="@Styles.css" text="Registrar Cliente" />
        
     
        <VBox layoutX="260.0" layoutY="50.0" prefHeight="82.0" prefWidth="114.0" styleClass="foto-container" stylesheets="@Styles.css">
            <children>
                <ImageView fx:id="imgFoto" fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true" />
            </children>
        </VBox>
        
     
        <HBox layoutX="180.0" layoutY="160.0" spacing="20.0">
            <children>
                <Button fx:id="btnTomarFoto" onAction="#tomarFoto" styleClass="foto-btn" stylesheets="@Styles.css" text="Tomar foto" />
                <Button fx:id="btnSubirFoto" onAction="#subirFoto" styleClass="foto-btn" stylesheets="@Styles.css" text="Subir foto" />
            </children>
        </HBox>
        
        
        <HBox layoutX="14.0" layoutY="220.0" spacing="20.0">
            <children>
                <MFXTextField fx:id="txtNombre" floatingText="Nombre" prefHeight="50.0" prefWidth="280.0" styleClass="form-mfx-field" stylesheets="@Styles.css" />
                <MFXTextField fx:id="txtApellidos" floatingText="Apellidos" prefHeight="50.0" prefWidth="280.0" styleClass="form-mfx-field" stylesheets="@Styles.css" />
            </children>
        </HBox>
        
        <HBox layoutX="14.0" layoutY="290.0" spacing="20.0">
            <children>
                <MFXTextField fx:id="txtCedula" floatingText="Cédula" maxHeight="50.0" prefHeight="50.0" prefWidth="280.0" styleClass="form-mfx-field" stylesheets="@Styles.css" />
                <DatePicker fx:id="dpFechaNacimiento" prefHeight="50.0" prefWidth="280.0" promptText="Fecha de nacimiento" styleClass="form-date-picker" stylesheets="@Styles.css" />
            </children>
        </HBox>
        
       
        <TableView fx:id="tablaClientes" layoutX="14.0" layoutY="360.0" prefHeight="200.0" prefWidth="572.0" styleClass="tabla-clientes" stylesheets="@Styles.css">
            <columns>
                <TableColumn fx:id="colCedula" prefWidth="150.0" text="Cédula" />
                <TableColumn fx:id="colNombre" prefWidth="250.0" text="Nombre Completo" />
                <TableColumn fx:id="colEdad" prefWidth="80.0" text="Edad" />
            </columns>
        </TableView>
        
      
        <HBox layoutX="14.0" layoutY="580.0" spacing="20.0">
            <children>
                <Button fx:id="btnGuardar" onAction="#guardarCliente" styleClass="btn-guardar" stylesheets="@Styles.css" text="Guardar" />
                <Button fx:id="btnLimpiar" onAction="#limpiarFormulario" styleClass="btn-limpiar" stylesheets="@Styles.css" text="Limpiar" />
                <Button fx:id="btnEliminar" onAction="#eliminarCliente" styleClass="btn-eliminar" stylesheets="@Styles.css" text="Eliminar" />
            </children>
        </HBox>
    </children>
</AnchorPane>
