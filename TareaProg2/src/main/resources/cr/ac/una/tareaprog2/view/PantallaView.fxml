<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.tareaprog2.controller.PantallaController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            
            <!-- Contenido central -->
            <center>
                <VBox spacing="20.0" alignment="CENTER">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        
                        <!-- Título -->
                        <Label text="PANTALLA DE PROYECCIÓN" style="-fx-font-weight: bold;">
                            <font>
                                <Font size="28.0" />
                            </font>
                        </Label>
                        
                        <!-- Ficha recién llamada (destacada) -->
                        <VBox alignment="CENTER" style="-fx-border-color: #3498db; -fx-border-width: 3; -fx-border-radius: 10; -fx-background-color: #e8f4fd; -fx-background-radius: 10;" spacing="10.0">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Label text="ÚLTIMO LLAMADO" style="-fx-text-fill: #2980b9; -fx-font-weight: bold;">
                                    <font>
                                        <Font size="18.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblUltimaFicha" text="Ficha #---" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                <Label fx:id="lblUltimaEstacion" text="Estación: ---" style="-fx-font-size: 24px; -fx-text-fill: #16a085;" />
                                <Label fx:id="lblUltimaHora" text="Hora: --:--:--" style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;" />
                            </children>
                        </VBox>
                        
                        <!-- Últimos 4 llamados -->
                        <Label text="ÚLTIMOS CLIENTES LLAMADOS" style="-fx-font-weight: bold;">
                            <font>
                                <Font size="20.0" />
                            </font>
                        </Label>
                        
                        <HBox spacing="15.0" alignment="CENTER">
                            <children>
                                <VBox fx:id="card1" alignment="CENTER" style="-fx-border-color: #bdc3c7; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-color: #ecf0f1; -fx-background-radius: 8;" spacing="5.0" prefWidth="150.0" prefHeight="120.0">
                                    <padding><Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/></padding>
                                    <children>
                                        <Label text="🎫" style="-fx-font-size: 32px;" />
                                        <Label fx:id="ficha1" text="---" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                                        <Label fx:id="estacion1" text="---" style="-fx-font-size: 14px;" />
                                        <Label fx:id="hora1" text="---" style="-fx-font-size: 11px;" />
                                    </children>
                                </VBox>
                                
                                <VBox fx:id="card2" alignment="CENTER" style="-fx-border-color: #bdc3c7; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-color: #ecf0f1; -fx-background-radius: 8;" spacing="5.0" prefWidth="150.0" prefHeight="120.0">
                                    <padding><Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/></padding>
                                    <children>
                                        <Label text="🎫" style="-fx-font-size: 32px;" />
                                        <Label fx:id="ficha2" text="---" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                                        <Label fx:id="estacion2" text="---" style="-fx-font-size: 14px;" />
                                        <Label fx:id="hora2" text="---" style="-fx-font-size: 11px;" />
                                    </children>
                                </VBox>
                                
                                <VBox fx:id="card3" alignment="CENTER" style="-fx-border-color: #bdc3c7; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-color: #ecf0f1; -fx-background-radius: 8;" spacing="5.0" prefWidth="150.0" prefHeight="120.0">
                                    <padding><Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/></padding>
                                    <children>
                                        <Label text="🎫" style="-fx-font-size: 32px;" />
                                        <Label fx:id="ficha3" text="---" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                                        <Label fx:id="estacion3" text="---" style="-fx-font-size: 14px;" />
                                        <Label fx:id="hora3" text="---" style="-fx-font-size: 11px;" />
                                    </children>
                                </VBox>
                                
                                <VBox fx:id="card4" alignment="CENTER" style="-fx-border-color: #bdc3c7; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-color: #ecf0f1; -fx-background-radius: 8;" spacing="5.0" prefWidth="150.0" prefHeight="120.0">
                                    <padding><Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/></padding>
                                    <children>
                                        <Label text="🎫" style="-fx-font-size: 32px;" />
                                        <Label fx:id="ficha4" text="---" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                                        <Label fx:id="estacion4" text="---" style="-fx-font-size: 14px;" />
                                        <Label fx:id="hora4" text="---" style="-fx-font-size: 11px;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        
                        <!-- Texto de avisos (corriendo) -->
                        <Label text="AVISOS" style="-fx-font-weight: bold;">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                        <ScrollPane prefHeight="60.0" style="-fx-background-color: #f39c12; -fx-background-radius: 5;">
                            <content>
                                <Label fx:id="lblAvisos" text="Bienvenido al sistema de fichas | Por favor mantener el orden | Gracias por su paciencia" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
                            </content>
                        </ScrollPane>
                        
                        <!-- Fecha y hora actual -->
                        <Label fx:id="lblFechaHora" text="dd/MM/yyyy HH:mm:ss" style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;" />
                        
                    </children>
                </VBox>
            </center>
            
        </BorderPane>
    </children>
</AnchorPane>