                  <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
               </BorderPane.margin>
               <graphic>
                  <ImageView fitHeight="10.0" fitWidth="10.0" pickOnBounds="true" preserveRatio="true" />
               </graphic>
            </MFXButton>
         </bottom>
         <top>
            <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true" styleClass="jfx-txt-logoImageView" BorderPane.alignment="CENTER">
               <image>
                  <Image url="@../resources/Logo.png" />
               </image>
            </ImageView>
         </top>
      </BorderPane>
   </left>
   <center>
      <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="550.0" prefWidth="0.0" BorderPane.alignment="CENTER" />
