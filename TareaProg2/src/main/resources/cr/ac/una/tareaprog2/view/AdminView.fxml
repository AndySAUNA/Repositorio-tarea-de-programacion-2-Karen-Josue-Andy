         <center>
            <VBox prefHeight="400.0" prefWidth="150.0" spacing="5.0">
               <children>
                  <MFXButton fx:id="btnConfiguraciones" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onAction="#onActionBtnConfiguraciones" prefHeight="50.0" styleClass="jfx-btn-configuracion" text="Configuraciones" VBox.vgrow="ALWAYS">
                     <VBox.margin>
                        <Insets top="3.0" />
                     </VBox.margin>
                     <graphic>
                        <ImageView fitHeight="23.0" fitWidth="7.0" pickOnBounds="true" preserveRatio="true" />
                     </graphic>
                  </MFXButton>
                  <MFXButton fx:id="btnTramites" layoutX="10.0" layoutY="10.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onAction="#onActionBtnTramites" prefHeight="50.0" styleClass="jfx-btn-tramites" text="Tramites" VBox.vgrow="ALWAYS">
                     <graphic>
                        <ImageView fitHeight="16.0" fitWidth="19.0" pickOnBounds="true" preserveRatio="true" />
                     </graphic></MFXButton>
                  <MFXButton fx:id="btnClientes" layoutX="10.0" layoutY="35.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onAction="#onActionBtnClientes" prefHeight="50.0" styleClass="jfx-btn-clientes" text="Clientes" VBox.vgrow="ALWAYS">
                     <graphic>
                        <ImageView fitHeight="16.0" fitWidth="19.0" pickOnBounds="true" preserveRatio="true" />
                     </graphic></MFXButton>
                  <MFXButton fx:id="btnMetricas" layoutX="10.0" layoutY="121.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onAction="#onActionBtnMetricas" prefHeight="50.0" styleClass="jfx-btn-metricas" text="Metricas" VBox.vgrow="ALWAYS">
                     <graphic>
                        <ImageView fitHeight="16.0" fitWidth="19.0" pickOnBounds="true" preserveRatio="true" />
                     </graphic></MFXButton>
                  <MFXButton fx:id="btnSucursales" layoutX="10.0" layoutY="176.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onAction="#onActionBtnSucursales" prefHeight="50.0" styleClass="jfx-btn-sucursales" text="Sucursales" VBox.vgrow="ALWAYS">
                     <graphic>
                        <ImageView fitHeight="16.0" fitWidth="19.0" pickOnBounds="true" preserveRatio="true" />
                     </graphic></MFXButton>
                  <MFXButton fx:id="btnEstaciones" layoutX="15.0" layoutY="240.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onAction="#onActionBtnEstaciones" prefHeight="50.0" styleClass="jfx-btn-Estacion" text="Estaciones" VBox.vgrow="ALWAYS">
                     <graphic>
                        <ImageView fitHeight="16.0" fitWidth="19.0" pickOnBounds="true" preserveRatio="true" />
                     </graphic>
                  </MFXButton>
               </children>
               <padding>
                  <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
               </padding>
            </VBox>
         </center>
         <bottom>
            <MFXButton fx:id="btnSalir" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onAction="#onActionBtnSalir" prefHeight="50.0" styleClass="jfx-btn-salir" text="Salir" BorderPane.alignment="CENTER">
